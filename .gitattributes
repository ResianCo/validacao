# Git LFS — Resian validation dataset
# Large/binary artifacts (xlsx, docx, csv snapshots, parquet, zip)
# are stored via Git LFS to keep the repo clone-friendly and avoid
# GitHub's 50 MB blob warning. Generated artifacts (PDF/PNG dashboards
# in outputs) are excluded by .gitignore, not LFS-tracked.

# Spreadsheets
*.xlsx       filter=lfs diff=lfs merge=lfs -text
*.xlsx.zip   filter=lfs diff=lfs merge=lfs -text
*.xlsm       filter=lfs diff=lfs merge=lfs -text
# Documents
*.docx       filter=lfs diff=lfs merge=lfs -text
*.doc        filter=lfs diff=lfs merge=lfs -text
*.pdf        filter=lfs diff=lfs merge=lfs -text
# Tabular / columnar
*.csv        filter=lfs diff=lfs merge=lfs -text
*.parquet    filter=lfs diff=lfs merge=lfs -text
*.tsv        filter=lfs diff=lfs merge=lfs -text
# Archives
*.zip        filter=lfs diff=lfs merge=lfs -text
*.tar.gz     filter=lfs diff=lfs merge=lfs -text
*.tgz        filter=lfs diff=lfs merge=lfs -text
# Images / dashboards
*.png        filter=lfs diff=lfs merge=lfs -text
*.jpg        filter=lfs diff=lfs merge=lfs -text
*.jpeg       filter=lfs diff=lfs merge=lfs -text
*.gif        filter=lfs diff=lfs merge=lfs -text
*.svg        filter=lfs diff=lfs merge=lfs -text
