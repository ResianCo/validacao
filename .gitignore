# Generated pipeline outputs (regenerated each run by bin/pipeline_csv.py)
/output/*
!/output/.gitkeep

# DuckDB spill dirs (regenerated at runtime)
/duck_tmp/
/input/duck_tmp/

# pytest cache + Python bytecode (Pass 5c)
/.pytest_cache/
/tests/__pycache__/
/bin/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
